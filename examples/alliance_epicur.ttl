# QualityLink prefix
@prefix ql: <http://data.quality-link.eu/ontology/v1#> .
# RDF basics
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
# European Learning Model (ELM)
@prefix elm: <http://data.europa.eu/snb/model/elm/> .
@prefix loq: <http://data.europa.eu/snb/model/ap/loq-constraints/> .
# Other used ontologies
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<http://data.quality-link.eu/alliance/INT6008>
    a ql:EuropeanUniversityAlliance ;
    adms:identifier [
        a ql:OrgRegIdentifier ;
        elm:schemeId ql:OrgReg ;
        elm:schemeName "ETER ID" ;
        skos:notation "INT6008"
    ] ;
    skos:prefLabel "EPICUR"@en .

# EPICUR
<https://data.deqar.eu/institution/1714> ql:isMemberOf <http://data.quality-link.eu/alliance/INT6008> .
